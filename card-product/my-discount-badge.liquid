{% comment %}
  (copyLeft) yRocket, Version 0.0.2026.3.28 (since 0.0.2026.3.28)
  Discount Badge Snippet
  Required: product
  Usage: snippets/card-product.liquid 수정
      if card_product.featured_media
      <div class="card__media ...">
        render 'my-discount-badge', product: card_product  ← 여기 삽입
        <div class="media media--transparent media--hover-effect">
        <img srcset="...
{% endcomment %}

{% assign init_value = product.metafields.custom.initial_price.value | plus: 0.0 %}
{% assign current_value = product.price %}

{% if init_value > 0 and current_value < init_value %}
  {% assign discount_pct = init_value | minus: current_value | divided_by: init_value | times: 100 | round %}
  {% if discount_pct > 1 %}
    <script>
      if (!document.getElementById('discount-badge-style')) {
        const style = document.createElement('style');
        style.id = 'discount-badge-style';
        style.textContent = `
          .discount-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            z-index: 9999;
            background: #E53E3E;
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            line-height: 1;
            padding: 5px 7px;
            border-radius: 7px;
            letter-spacing: 0.04em;
            pointer-events: none;
            user-select: none;
          }
        `;
        document.head.appendChild(style);
      }
    </script>
    <div class="discount-badge">{{ discount_pct }}% OFF</div>
  {% endif %}
{% endif %}