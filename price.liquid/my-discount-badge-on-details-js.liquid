{% comment %}
  (copyLeft) yRocket, Version 0.0.2026.3.28 (since 0.0.2026.3.28)
  Discount Badge JS+CSS Snippet - Product Detail Page
  Required: product
  Usage: sections/main-product.liquid 에서 schema 바로 위에 추가
      render 'my-discount-badge-on-details-js', product: product
{% endcomment %}

<style>
  .discount-label {
    display: inline-block;
    background: #E53E3E;
    color: #fff;
    font-size: 17px;
    font-weight: 700;
    line-height: 1;
    padding: 5px 7px;
    border-radius: 7px;
    letter-spacing: 0.04em;
    pointer-events: none;
    user-select: none;
    vertical-align: middle;
  }
</style>

<script>
  (function() {
    const variants = {
      {%- for variant in product.variants -%}
        "{{ variant.id }}": {
          "price": {{ variant.price }},
          "compare_at_price": {{ variant.compare_at_price | default: 0 }}
        }
        {%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    };

    function updateLabel(variantId) {
      const label = document.getElementById('discount-label-pct');
      if (!label) return;

      const v = variants[String(variantId)];
      if (!v || v.compare_at_price <= v.price) {
        label.style.display = 'none';
        return;
      }

      const pct = Math.round((v.compare_at_price - v.price) * 100 / v.compare_at_price);
      if (pct > 1) {
        label.textContent = pct + '% OFF';
        label.style.display = 'inline-block';
      } else {
        label.style.display = 'none';
      }
    }

    document.addEventListener('change', function(e) {
      if (e.target && e.target.name === 'id') {
        updateLabel(e.target.value);
      }
    });

    document.addEventListener('variant:changed', function(e) {
      if (e.detail && e.detail.variant) {
        updateLabel(e.detail.variant.id);
      }
    });
  })();
</script>